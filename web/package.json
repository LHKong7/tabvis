{
  "name": "tabvis-console",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Tabvis agent console — React front-end for the tabvis HTTP/SSE API. Run live with `tabvis --serve --dev`, or `npm run build` to web/dist and host it yourself.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
