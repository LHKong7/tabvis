# Node / web console. Source in web/; tabvis ships NO built-in UI (headless API). The console is
# run live with `tabvis --serve --dev`, or built to web/dist and hosted externally — never committed.
node_modules/
web/dist/
*.tsbuildinfo
tabvis/browser/static/          # legacy built-console location; no longer produced or served
# NOTE: web/package-lock.json IS committed (locks JS deps, like uv.lock).
