# ---------------------------------------------------------------------------------------------
# tabvis — environment template
#
#   cp .env.example .env      then fill in TABVIS_API_KEY
#
# `.env` is auto-loaded at startup (from the directory you launch tabvis in, then ~/.tabvis/.env) and
# is gitignored. A real exported shell variable always beats a value in here.
#
# Everything below is commented out and shows its DEFAULT, except the two required settings.
# You can also set most of these from the web console (`tabvis --serve` -> Settings) — they apply
# live, no restart, and get merged back into this file.
# ---------------------------------------------------------------------------------------------


# =============================================================================================
# REQUIRED — tabvis will not make a model call without these
# =============================================================================================

# The model API endpoint. There is NO default: tabvis refuses to run without it, rather than
# silently talking to some other endpoint.
TABVIS_BASE_URL=

# Your API key. Paste it after the '=' below.
#
#   ⚠ It MUST be spelled TABVIS_API_KEY. A plain ANTHROPIC_API_KEY does not work — tabvis actively
#     DELETES ANTHROPIC_* variables whose TABVIS_* counterpart is unset, so one sitting in your
#     shell profile is wiped, not used.
TABVIS_API_KEY=

# A bearer/OAuth token INSTEAD of the API key. Set one or the other, not both.
#TABVIS_AUTH_TOKEN=


# =============================================================================================
# MODEL
# =============================================================================================

# Which model to use. Blank = the built-in default (claude-sonnet-4-6).
# Aliases (tabvis-max, tabvis-balanced, tabvis-fast) work HERE but NOT via --model, which is sent to
# the API verbatim. Context suffixes work too, e.g. tabvis-balanced[1m].
#TABVIS_MODEL=

# Repoint a whole tier — useful when your endpoint serves different model ids. These apply when the
# model is chosen via a tier alias (tabvis-max/-balanced/-fast, or opus/sonnet/haiku) or left default.
#TABVIS_DEFAULT_SONNET_MODEL=
#TABVIS_DEFAULT_OPUS_MODEL=
#TABVIS_DEFAULT_HAIKU_MODEL=

#TABVIS_MAX_OUTPUT_TOKENS=8192       # max_tokens per request

# --- Model provider (Anthropic | OpenAI | Gemini) --------------------------------------------
# tabvis is Anthropic-native, but the model layer is unified behind a provider abstraction that
# translates requests/streams both ways, so it can also drive OpenAI (Chat Completions) or Gemini.
#   Provider is inferred from the model id (gpt*/o1/o3/o4 -> openai, gemini* -> gemini, else
#   anthropic); TABVIS_MODEL_PROVIDER forces it. The SDKs are optional extras — a provider errors with
#   an install hint if its package is missing (never a silent downgrade).
#TABVIS_MODEL_PROVIDER=              # anthropic (default) | openai | gemini
#   OpenAI (uv sync --extra openai). Works with any OpenAI-compatible endpoint (vLLM/Groq/…).
#TABVIS_OPENAI_API_KEY=              # or OPENAI_API_KEY
#TABVIS_OPENAI_BASE_URL=             # or OPENAI_BASE_URL (a gateway/compatible endpoint)
#   Gemini (uv sync --extra gemini).
#TABVIS_GEMINI_API_KEY=              # or GEMINI_API_KEY / GOOGLE_API_KEY
#TABVIS_GEMINI_BASE_URL=
#API_TIMEOUT_MS=600000             # per-request timeout (10 min)
#TABVIS_CUSTOM_HEADERS=              # extra headers, "Name: Value" per line (gateways/proxies)
#ENABLE_TOOL_SEARCH=               # tool search auto-disables on non-Anthropic base URLs


# =============================================================================================
# VISION / OCR
# =============================================================================================

# How images reach the model. A multimodal model gets native image input (browser screenshots,
# @-mentioned image files, pastes); a TEXT-ONLY model can't see images, so tabvis extracts their
# text with Tesseract and sends that instead — the image-understanding capability is enabled when
# EITHER a vision model OR an OCR engine is present, and gated off (with a short note) when neither.

# Force the vision decision. Blank = auto-detect from the model id (claude-3+/gpt-4o/o*/gemini-1.5+
# are treated as multimodal; gpt-3.5, custom text-only endpoints, etc. are not). Set 1 to force
# native image input for a custom multimodal endpoint the id can't reveal, or 0 to force the OCR path.
#TABVIS_MODEL_SUPPORTS_VISION=

# OCR fallback for non-vision models. On by default; 0 drops images with a short note instead of
# OCR'ing them. Needs an OCR engine — the layered detector uses the first available of tesserocr
# (uv sync --extra ocr), pytesseract (+Pillow), or a `tesseract` binary on PATH. Install the engine
# per OS: macOS `brew install tesseract`, Debian/Ubuntu `apt install tesseract-ocr`, Windows
# `choco install tesseract`.
#TABVIS_OCR_ENABLED=1

# Tesseract language(s), e.g. eng or eng+chi_sim. Extra languages need their traineddata installed
# (macOS `brew install tesseract-lang`, Ubuntu `apt install tesseract-ocr-chi-sim`). Languages that
# are not installed are dropped, falling back to an installed one.
#TABVIS_OCR_LANG=eng

# Force one OCR engine instead of auto-detecting: tesserocr | pytesseract | binary.
#TABVIS_OCR_ENGINE=auto


# =============================================================================================
# PROJECT INSTRUCTIONS
# =============================================================================================

# Tabvis automatically loads plain-Markdown TABVIS.md files from the Git root through the current
# working directory. Nested files take precedence. Loading is context-limited and intentionally
# does not support includes, frontmatter, or rule matching. Set this to 1 to ignore all TABVIS.md
# files (TABVIS_SIMPLE / --bare also uses the minimal prompt and skips them).
#TABVIS_DISABLE_TABVIS_MDS=0


# =============================================================================================
# BROWSER AGENT  (Playwright / Chromium)
# =============================================================================================

# Which browser the agent drives — the most consequential setting in this section. Every engine
# ends up as an ordinary Playwright BrowserContext, so the Browser* tools, the snapshot/ref
# machinery and the persistent profile are identical; the engine only picks the binary and how it
# is obtained. Values (grouped by mechanism):
#
#   NATIVE LAUNCH (Playwright starts the binary)
#     chromium   Stock Playwright Chromium (default). Fast, nothing to install, and trivially
#                detectable (navigator.webdriver true, "HeadlessChrome" UA, SwiftShader GPU). Right
#                for driving your own app or any site that is not scoring you.
#     chrome     Your installed Google Chrome (via Playwright channel=chrome).
#     msedge     Your installed Microsoft Edge (via channel=msedge).
#     brave/vivaldi/opera   Installed Chromium-family browser; the binary is auto-detected in the
#                usual locations (override with TABVIS_BROWSER_EXECUTABLE_PATH).
#     firefox    Playwright's automation Firefox. (A system Firefox: firefox + EXECUTABLE_PATH.)
#     webkit     Playwright WebKit — the supported stand-in for Safari (Safari can't be driven).
#
#   STEALTH (a fingerprint-patched build; needs an optional package)
#     cloak      CloakBrowser — Chromium patched at the C++ source level. `uv sync --extra cloak`.
#     camoufox   Camoufox — the Firefox-kernel counterpart. `uv sync --extra camoufox`.
#     Without the package the launch FAILS rather than quietly falling back to stock — a silent
#     downgrade would hand a run that asked for stealth the one browser guaranteed to get it blocked.
#
#   ATTACH TO AN EXISTING BROWSER (nothing launched locally)
#     cdp        Any Chromium exposing a DevTools endpoint — set TABVIS_BROWSER_CDP_ENDPOINT.
#     steel      Steel Browser (point TABVIS_BROWSER_CDP_ENDPOINT at the session's CDP address).
#     adspower/gologin/multilogin/octo/dolphin/kameleo   Commercial anti-detect browsers: start the
#                profile via the vendor's local API, then pass tabvis the CDP address it returns in
#                TABVIS_BROWSER_CDP_ENDPOINT. (Multilogin Mimic = Chromium; its Stealthfox/Firefox
#                profile is not driveable this way.)
#     connect    A remote Playwright *server* — set TABVIS_BROWSER_WS_ENDPOINT.
#     browserless/browserbase   Managed browser services (Playwright/ws endpoint or CDP).
#
#   ⚠ Each launch/plugin engine keeps its OWN profile, so switching engines gives you a browser that
#     is LOGGED OUT of everything. See TABVIS_BROWSER_USER_DATA_DIR below. (cdp/connect engines have no
#     local profile — the remote browser owns it.)
#TABVIS_BROWSER_ENGINE=chromium

# Pre-launch Chromium at session start so the first BrowserNavigate is ~25ms instead of ~1s.
# Set to 0 for non-browsing workloads — otherwise every run spawns a browser it never uses.
#TABVIS_BROWSER_EAGER=1

# The agent LIVES in a real browser window — headed is the default. You can watch it navigate,
# see exactly what it saw, and take the wheel yourself.
#   Set to 1 only for CI/containers with no display. (A headed launch on a display-less machine
#   degrades to headless automatically, so you rarely need to.)
#TABVIS_BROWSER_HEADLESS=0

# The browser is BUNDLED to the agent that spawned it — its environment, not a per-run resource. It
# is reserved at spawn, kept open across runs (tabs and logins intact), and lives until the user
# quits the agent (or the process exits). A bundled browser is NEVER idle-reaped.
#   This timeout only reaps *unowned* workspaces (a library/test caller that never quit one); it does
#   not touch an agent's bundled browser. 0 = never reap even those.
#TABVIS_BROWSER_IDLE_TIMEOUT_MS=1800000   # 30 min

# The persistent Chromium profile — this is what makes cookies and logins survive across runs.
# Each engine defaults to its OWN profile: ~/.tabvis/browser for chromium, ~/.tabvis/browser-cloak for
# cloak. They are different Chromium builds (cloak's free tier is 145, Playwright bundles 149), and
# Chromium migrates a profile FORWARD the first time a newer build opens it — hand that upgraded
# profile back to the older binary and you get a refused launch or a corrupted profile. A stealth
# session also has no business inheriting cookies and storage written by a browser that was never
# trying to be stealthy.
#
#   ⚠ The price of that separation: switching engines starts you LOGGED OUT. Plan to sign in twice.
#   ⚠ Setting this explicitly points BOTH engines at ONE directory — your call, and the version
#     skew above becomes your problem. tabvis still refuses to run two engines against it at once:
#     it closes the running browser and relaunches rather than serve a stealth run a stock one.
#TABVIS_BROWSER_USER_DATA_DIR=~/.tabvis/browser

# Host allowlist for navigation, comma-separated. Exact (example.com) or glob (*.example.com).
#
#   ⚠ EMPTY = ALLOW EVERY DOMAIN. Setting this is what turns gating ON.
#   ⚠ A wildcard does NOT cover the apex: *.example.com does not match example.com. List both.
#   ⚠ It gates BrowserNavigate `goto` only. BrowserClick/BrowserType are ungated, so a click on a
#     link can still carry the agent off the allowlist. Treat it as a guard on where the agent
#     STARTS, not a guarantee of where it stays.
#TABVIS_BROWSER_ALLOWED_DOMAINS=

# --- Request pacing (be a polite client, never a burst) --------------------------------------
# The agent can fire navigations and clicks far faster than a person; a tight loop of page loads
# against one host is indistinguishable from a denial-of-service. These pace the request-causing
# actions (navigate + click, and Enter-to-submit). Only a REAL remote host is paced — localhost and
# host-less URLs (data:, about:blank) are exempt, so local dev/tests stay fast. Limits are
# process-wide, so several concurrent agents SHARE the per-host budget.
#TABVIS_BROWSER_MIN_REQUEST_INTERVAL_MS=1000   # min gap between navigations/clicks to one host
#TABVIS_BROWSER_MAX_REQUESTS_PER_MINUTE=0      # hard per-host burst ceiling over 60s (0 = off)
#TABVIS_BROWSER_MIN_ACTION_INTERVAL_MS=0       # min gap between ANY two actions (0 = off)
#TABVIS_BROWSER_REQUEST_JITTER_MS=0            # random 0..N ms per slot (de-synchronise agents)
#TABVIS_BROWSER_MAX_PACING_WAIT_MS=60000       # safety cap on a single pacing wait

# --- Download workspace ----------------------------------------------------------------------
# Where browser downloads AND fetched web PDFs land, so the agent can Read/evaluate them. Every
# browser download is auto-saved here; navigating to a PDF grabs its bytes here; the BrowserDownload
# tool fetches an explicit URL here. Blank = a per-run default beside that session's browser
# artifacts: <config-home>/projects/<sanitized-cwd>/<session-id>/workspace/. Set an absolute path to
# collect everything in one folder you watch. Filenames never clobber (report.pdf -> report (2).pdf).
#TABVIS_WORKSPACE_DIR=~/tabvis-downloads

#TABVIS_BROWSER_VIEWPORT=1280x720    # WIDTHxHEIGHT (lowercase x)
#TABVIS_BROWSER_CHANNEL=chromium     # chromium (bundled) | chrome | msedge — launch-mode Chromium only
#TABVIS_BROWSER_EXECUTABLE_PATH=     # explicit binary — skips `playwright install` / auto-detect
#TABVIS_BROWSER_TIMEOUT_MS=30000     # per browser operation
#TABVIS_BROWSER_ARGS=                # extra Chromium args, comma-separated (e.g. --no-sandbox)
#TABVIS_BROWSER_SNAPSHOT_MODE=       # 'data' forces the injected-attribute snapshot path
# The snapshot is the public aria tree (page.aria_snapshot mode='ai'), each node tagged [ref=eN].
# When that tree is too sparse to reason from (a canvas game, a map, an image-only page), a
# screenshot + trimmed page HTML are attached automatically. Set to 0 for a text-only snapshot.
#TABVIS_BROWSER_AUTO_VISUAL=1

# Browsing artifacts — the durable trail of what the agent did in the browser (navigation, page
# metadata, interactions, and the DOM at each step). Written next to browser-session.json under the
# per-session dir: browser-artifacts/events.jsonl + dom/<hash>.html. Read via GET /agents/<id>/artifacts.
#TABVIS_BROWSER_ARTIFACTS=1                  # 0 to disable recording entirely
#TABVIS_BROWSER_ARTIFACTS_DOM=1              # 0 to skip capturing the DOM (saves an evaluate + disk)
#TABVIS_BROWSER_ARTIFACTS_MAX_DOM_BYTES=1000000   # cap per DOM blob
#TABVIS_BROWSER_ARTIFACTS_REDACT_INPUT=0     # 1 to store typed text as length-only (hides passwords)

# Remote-attach endpoints — only the one matching the engine's mode is read.
#   cdp-mode engines (cdp/steel/adspower/gologin/multilogin/octo/dolphin/kameleo): the browser's
#   DevTools address, either http://host:port or the ws://…/devtools/browser/… URL its API returns.
#TABVIS_BROWSER_CDP_ENDPOINT=        # e.g. http://127.0.0.1:9222
#   connect-mode engines (connect/browserless/browserbase): a Playwright-server ws:// / wss:// URL.
#   May carry a ?token=… credential — it is redacted before tabvis logs or serves it.
#TABVIS_BROWSER_WS_ENDPOINT=         # e.g. wss://chrome.browserless.io?token=…


# =============================================================================================
# STEALTH BROWSER  (TABVIS_BROWSER_ENGINE=cloak only)
# =============================================================================================

# Every key below is read ONLY under the cloak engine. Under the default chromium engine they
# are inert, not an error — so you can leave a stealth setup configured and switch back.
#
#   ⚠ The FIRST cloak launch downloads ~140MB of patched Chromium into ~/.cloakbrowser (the
#     archive is signature-verified). Every launch after that is cached. Do it once, on a
#     connection you trust, before you need it — not in the middle of a timed run.
#   ⚠ cloak drives its own binary, so TABVIS_BROWSER_CHANNEL and TABVIS_BROWSER_EXECUTABLE_PATH are
#     IGNORED (tabvis says so in debug logs rather than dropping them silently). Pointing the
#     stealth engine at your stock installed Chrome would defeat the entire point of it.

# CloakBrowser Pro license key. Unset = the free tier, which pins Chromium 145. A key unlocks
# the newer binary and the newest anti-bot patches — worth it only if the free tier is losing.
#
#   ⚠ ENV-ONLY, DELIBERATELY. A few browser keys are env-only (TABVIS_BROWSER_EAGER, _ARGS,
#     _IDLE_TIMEOUT_MS, _SNAPSHOT_MODE simply aren't wired into settings.json) — but this one is
#     env-only ON PURPOSE. It is a credential, and settings.json is plain config that the web
#     console reads back and the HTTP API serves. Nothing that reaches a session record or an API
#     response should be able to carry a key you paid for.
#   ⚠ CloakBrowser's own CLOAKBROWSER_LICENSE_KEY is honoured too, so a machine already set up
#     for CloakBrowser needs nothing here.
#TABVIS_BROWSER_CLOAK_LICENSE_KEY=

# Human-like input: the cursor travels a curve before it clicks, keystrokes land with randomised
# gaps instead of all in one tick. This defeats BEHAVIOURAL scoring — the fingerprint is already
# handled by the patched binary, so turn it on only when a site is watching HOW you act.
#
#   ⚠ It is genuinely slow: measured at roughly HALF A SECOND PER CHARACTER typed. A 40-char
#     field costs ~20 seconds. That cost is the whole reason it is off by default. (tabvis scales
#     its per-action timeout with the length of the text, so a long humanized fill is not
#     cancelled mid-word — but the wall clock is still the wall clock.)
#TABVIS_BROWSER_HUMANIZE=0
#TABVIS_BROWSER_HUMAN_PRESET=default # default | careful (slower, most paranoid sites)

# Route the browser through a proxy — http://, https:// or socks5://, credentials inline if you
# need them. tabvis strips user:pass out of the URL before it is logged, persisted to the session
# record, or served over the API, so the password does not leak out the side.
#TABVIS_BROWSER_PROXY=

# A browser claiming a Berlin exit IP while reporting a New York clock and en-US formatting is a
# tell that no amount of fingerprint patching hides. geoip derives timezone and locale from the
# proxy's actual exit IP, which is the honest fix; it costs one lookup at launch and does nothing
# without a proxy set. Pin them by hand instead if you know better than the lookup does.
#TABVIS_BROWSER_GEOIP=0
#TABVIS_BROWSER_TIMEZONE=            # IANA name, e.g. America/New_York
#TABVIS_BROWSER_LOCALE=              # e.g. en-US

#TABVIS_BROWSER_CLOAK_VERSION=       # pin a CloakBrowser build (default: whatever ships)


# =============================================================================================
# HTTP SERVER  (tabvis --serve)
# =============================================================================================

#TABVIS_SERVER_HOST=127.0.0.1        # or --host
#TABVIS_SERVER_PORT=8765             # or --port

# How many agents may run at once. Each running agent is one REAL Chromium process.
#TABVIS_SERVER_MAX_AGENTS=4

# The server has NO AUTHENTICATION. Config changes (setting a key, repointing TABVIS_BASE_URL) are
# therefore refused from anything but localhost. Only set this if you have an auth proxy in front
# — otherwise anyone who can reach the port could plant a credential or harvest your prompts.
#TABVIS_SERVER_ALLOW_REMOTE_CONFIG=0


# =============================================================================================
# PERMISSIONS & POLICY
# =============================================================================================

# Before it runs, every file-write, shell, and browser action is classified by its side-effect
# (filesystem.write, shell.execute, browser.navigate, browser.download, network.request, …) and
# checked against a policy engine that answers allow / deny / ask. A deny always wins and is never
# grantable. Most rules live in settings.json (permissions.mode / permissions.rules); the knobs
# below are the env overrides.

# The permission MODE — the baseline every run starts from. Precedence: this var >
# settings.json `permissions.mode` > standard. An invalid value is a hard config error, not a
# silent fallback.
#   trusted   allow by default; no guard rails. For throwaway/sandboxed environments only.
#   standard  (default) allow reads/writes inside the workspace, protect config files, and ASK
#             before anything external: downloads, uploads, network, credential use, clipboard,
#             exports. In headless -p runs an ASK resolves to DENY (there is nothing to prompt).
#   locked    deny by default; only an explicit read-only allow-list gets through.
#TABVIS_PERMISSION_MODE=standard

# Shadow mode: COMPUTE every decision and write it to the audit trail, but never actually block —
# each non-allow is served as allow. Use it to see what `standard`/`locked` WOULD stop before you
# enforce it. Truthy = 1/true/yes/on.
#TABVIS_PERMISSION_SHADOW=0

# Decision audit trail — one structured `policy.decision` log line per check (url query/secrets
# redacted). ON by default; set a falsy value (0/false/no/off) to turn it off.
#TABVIS_PERMISSION_AUDIT=1

# Strict filesystem baseline. Off = the agent may read/write throughout its working directory. On =
# only the workspace/session tree is writable; a write to any OTHER path (`fs:`) needs an explicit
# directory grant, and reads of secret-looking files (.env, *.key/.pem, credentials.json, …) are
# denied. Writes to config/secret paths are ALWAYS denied, strict or not.
#TABVIS_PERMISSION_FS_STRICT=0

# Strict bash baseline. Off = shell commands run under the default allow. On = commands that look
# like they reach the network (curl/wget/ssh/scp/nc/…) fall to ASK instead. This is a heuristic
# convenience, NOT a security boundary — real egress control belongs to a sandbox/proxy.
#TABVIS_PERMISSION_BASH_STRICT=0


# =============================================================================================
# IM CHANNELS  (Feishu, DingTalk, Slack, …)
# =============================================================================================

# Credentials for the messaging channel plugins in tabvis/channels/plugins/. Each plugin reads its
# own TABVIS_<PLATFORM>_* vars via from_env(); the ones below are the minimum for a text bot (see the
# plugin's client.py for the full set). Platforms whose inbound uses AES or public-key crypto need an
# extra: `uv sync --extra feishu|wecom|teams|google_chat`.
#   ⚠ These configure the channel plugins, but the HTTP webhook ingress that drives them is not yet
#     mounted in `tabvis --serve` (design §4 Phase 4). They are usable programmatically and under test
#     today; a mounted route is future work.

# Feishu / 飞书 / Lark — event-subscription webhook. DOMAIN: feishu (China) | lark (International).
#TABVIS_FEISHU_APP_ID=
#TABVIS_FEISHU_APP_SECRET=
#TABVIS_FEISHU_ENCRYPT_KEY=          # optional — enables encrypted events + signature check
#TABVIS_FEISHU_VERIFICATION_TOKEN=   # optional — checked against header.token
#TABVIS_FEISHU_DOMAIN=feishu

# DingTalk / 钉钉 — HTTP outgoing-robot callback (timestamp+sign HMAC over the app secret).
#TABVIS_DINGTALK_CLIENT_ID=
#TABVIS_DINGTALK_CLIENT_SECRET=
#TABVIS_DINGTALK_ROBOT_CODE=

# WeCom / 企业微信 — WXBizMsgCrypt callback (SHA1 signature + AES-256-CBC; needs --extra wecom).
#TABVIS_WECOM_CORP_ID=
#TABVIS_WECOM_CORP_SECRET=
#TABVIS_WECOM_AGENT_ID=
#TABVIS_WECOM_TOKEN=
#TABVIS_WECOM_ENCODING_AES_KEY=      # 43-char EncodingAESKey

# Slack — Events API (X-Slack-Signature v0 HMAC over the signing secret).
#TABVIS_SLACK_BOT_TOKEN=             # xoxb-… bot token (outbound chat.postMessage)
#TABVIS_SLACK_SIGNING_SECRET=        # inbound request signature

# Microsoft Teams — Bot Framework (inbound RS256 JWT bearer; needs --extra teams).
#TABVIS_TEAMS_CLIENT_ID=
#TABVIS_TEAMS_CLIENT_SECRET=
#TABVIS_TEAMS_TENANT_ID=

# LINE — Messaging API (X-Line-Signature base64 HMAC over the channel secret).
#TABVIS_LINE_CHANNEL_ACCESS_TOKEN=
#TABVIS_LINE_CHANNEL_SECRET=

# Google Chat — OIDC id-token verification + Service Account send (needs --extra google_chat).
#TABVIS_GOOGLE_CHAT_AUDIENCE=
#TABVIS_GOOGLE_CHAT_SERVICE_ACCOUNT_JSON=   # path to the SA key JSON

# WhatsApp Cloud (Meta Graph) — X-Hub-Signature-256 HMAC + hub.challenge verify handshake.
#TABVIS_WHATSAPP_ACCESS_TOKEN=
#TABVIS_WHATSAPP_PHONE_NUMBER_ID=
#TABVIS_WHATSAPP_APP_SECRET=
#TABVIS_WHATSAPP_VERIFY_TOKEN=


# =============================================================================================
# DEBUGGING
# =============================================================================================

# ⚠ Presence-checked, NOT parsed: ANY value turns it on, including TABVIS_DEBUG=0.
#   To turn it off, remove the line. A bare DEBUG variable enables it too.
#TABVIS_DEBUG=1

#TABVIS_LOG=debug                    # the Anthropic SDK's own HTTP request logging
#TABVIS_SIMPLE=1                     # minimal prompt, reduced tool set, no MCP (isolate config bugs)


# =============================================================================================
# CONFIG PLUMBING  (rarely needed)
# =============================================================================================

#TABVIS_CONFIG_DIR=~/.tabvis           # relocates settings.json, the browser profile, agent records
#TABVIS_DOTENV=/path/to/file         # load ONE explicit .env instead of the default pair
#TABVIS_DISABLE_DOTENV=1             # turn .env autoloading off (must come from the REAL env)
